{
  "mcpServers": {
    "opencaselist": {
      "command": "/path/to/opencaselist-mcp/.venv/bin/python3.12",
      "args": ["/path/to/opencaselist-mcp/server.py"],
      "env": {
        "OPENCASELIST_BASE_URL": "https://opencaselist.com",
        "OPENCASELIST_USERNAME": "",
        "OPENCASELIST_PASSWORD": ""
      }
    }
  }
}
